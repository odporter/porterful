'use client'

import { useState, useRef, useEffect } from 'react'
import Image from 'next/image'
import { useAudio } from '@/lib/audio-context'
import { TRACKS } from '@/lib/data'
import Link from 'next/link'

const PREVIEW_SECONDS = 99
const LIFETIME_PRICE = 5.99

// Radio Station Icons
const Icon = {
  Play: () => <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><polygon points="5,3 19,12 5,21"/></svg>,
  Pause: () => <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><rect x="6" y="4" width="4" height="16" rx="1"/><rect x="14" y="4" width="4" height="16" rx="1"/></svg>,
  Search: () => <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="2"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>,
  Fire: () => <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="2"><path d="M8.5 14.5A2.5 2.5 0 0 0 11 12c0-1.38-.5-2-1-3-1.072-2.143-.224-4.054 2-6 .5 2.5 2 4.9 4 6.5 2 1.6 3 3.5 3 5.5a7 7 0 1 1-14 0c0-1.153.433-2.294 1-3a2.5 2.5 0 0 0 2.5 2.5z"/></svg>,
  Lock: () => <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="2"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>,
}

// Buy Track - goes straight to checkout
async function buyTrack(track: typeof TRACKS[0], setLoading: (v: boolean) => void, setError: (v: string) => void) {
  setLoading(true)
  setError('')
  try {
    const res = await fetch('/api/checkout', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({
        items: [{
          productId: track.id,
          name: track.title,
          artist: track.artist,
          image: track.image,
          price: track.price,
          quantity: 1,
          type: 'track',
          audioUrl: track.audio_url,
        }]
      })
    })
    const data = await res.json()
    if (data.url) {
      window.location.href = data.url
    } else {
      setError('Could not start checkout. Please try again.')
      setLoading(false)
    }
  } catch {
    setError('Something went wrong.')
    setLoading(false)
  }
}

// Buy All Access - lifetime pass
async function buyAllAccess(setLoading: (v: boolean) => void, setError: (v: string) => void) {
  setLoading(true)
  setError('')
  try {
    const res = await fetch('/api/checkout', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({
        items: [{
          productId: 'lifetime-access',
          name: 'Lifetime Access - All Music',
          artist: 'Porterful',
          image: 'https://images.unsplash.com/photo-1511671782779-c97d3d27a1d4?w=200',
          price: LIFETIME_PRICE,
          quantity: 1,
          type: 'lifetime',
        }]
      })
    })
    const data = await res.json()
    if (data.url) {
      window.location.href = data.url
    } else {
      setError('Could not start checkout. Please try again.')
      setLoading(false)
    }
  } catch {
    setError('Something went wrong.')
    setLoading(false)
  }
}

function TrackRow({ track, onPlay, currentTrack, isPreviewOver }: {
  track: typeof TRACKS[0]
  onPlay: () => void
  currentTrack: any
  isPreviewOver: boolean
}) {
  const [loading, setLoading] = useState(false)
  const [error, setError] = useState('')
  const isPlaying = currentTrack?.id === track.id

  return (
    <div className={`flex items-center gap-3 p-3 rounded-xl transition-colors ${
      isPlaying ? 'bg-[var(--pf-orange)]/10 border border-[var(--pf-orange)]' : 'bg-[var(--pf-surface)] border border-[var(--pf-border)] hover:border-[var(--pf-orange)]/50'
    }`}>
      {/* Play button + Album art */}
      <button onClick={onPlay} className="w-12 h-12 rounded-lg overflow-hidden shrink-0 relative group">
        <Image src={track.image} alt={track.title} fill className="object-cover" />
        <div className="absolute inset-0 bg-black/40 flex items-center justify-center opacity-0 group-hover:opacity-100 transition-opacity">
          {isPlaying ? <Icon.Pause /> : <Icon.Play />}
        </div>
      </button>

      {/* Track info */}
      <div className="flex-1 min-w-0">
        <p className={`font-medium truncate ${isPlaying ? 'text-[var(--pf-orange)]' : 'text-[var(--pf-text)]'}`}>
          {track.title}
        </p>
        <p className="text-sm text-[var(--pf-text-secondary)] truncate">{track.artist}</p>
      </div>

      {/* Price + Buy */}
      <div className="flex items-center gap-2 shrink-0">
        {isPreviewOver ? (
          <button
            onClick={() => buyTrack(track, setLoading, setError)}
            disabled={loading}
            className="px-4 py-2 bg-gradient-to-r from-[var(--pf-orange)] to-orange-500 text-white rounded-lg text-sm font-medium hover:opacity-90 transition-opacity disabled:opacity-50 flex items-center gap-1"
          >
            {loading ? '...' : isPlaying ? 'Playing' : `Buy $${track.price}`}
          </button>
        ) : (
          <span className="text-sm text-[var(--pf-text-muted)]">
            {isPlaying ? '🎧 Now playing' : `$${track.price}`}
          </span>
        )}
      </div>
    </div>
  )
}

export default function DigitalPage() {
  const { currentTrack, playTrack } = useAudio()
  const [search, setSearch] = useState('')
  const [previewTimeLeft, setPreviewTimeLeft] = useState(PREVIEW_SECONDS)
  const [previewActive, setPreviewActive] = useState(false)
  const timerRef = useRef<NodeJS.Timeout | null>(null)

  // Filter tracks by search
  const filteredTracks = search
    ? TRACKS.filter(t =>
        t.title.toLowerCase().includes(search.toLowerCase()) ||
        t.artist.toLowerCase().includes(search.toLowerCase()) ||
        t.album.toLowerCase().includes(search.toLowerCase())
      )
    : TRACKS

  // Preview countdown when playing
  useEffect(() => {
    if (currentTrack) {
      setPreviewActive(true)
      setPreviewTimeLeft(PREVIEW_SECONDS)
      if (timerRef.current) clearInterval(timerRef.current)
      timerRef.current = setInterval(() => {
        setPreviewTimeLeft(t => {
          if (t <= 1) {
            clearInterval(timerRef.current!)
            return 0
          }
          return t - 1
        })
      }, 1000)
      return () => {
        if (timerRef.current) clearInterval(timerRef.current)
      }
    } else {
      setPreviewActive(false)
      setPreviewTimeLeft(PREVIEW_SECONDS)
    }
  }, [currentTrack?.id])

  const isPreviewOver = previewTimeLeft === 0 && currentTrack !== null

  return (
    <div className="min-h-screen pb-24">
      {/* Radio Station Header */}
      <div className="bg-gradient-to-r from-[var(--pf-orange)] via-orange-500 to-purple-600 px-6 py-8 md:py-10">
        <div className="pf-container">
          <div className="flex items-center gap-3 mb-2">
            <span className="text-3xl">🎧</span>
            <div>
              <h1 className="text-2xl md:text-4xl font-bold text-white tracking-tight">
                Hot 99.9 Porterful Radio
              </h1>
              <p className="text-white/70 text-sm">Stream music. Buy what you love. Support artists directly.</p>
            </div>
          </div>

          {/* Preview bar */}
          {currentTrack && (
            <div className="mt-4 bg-black/20 rounded-xl p-3 flex items-center gap-4">
              <div className="flex items-center gap-2 text-white">
                <span className={previewTimeLeft <= 10 ? 'text-red-300 animate-pulse' : ''}>
                  {previewTimeLeft}s
                </span>
                <div className="w-24 h-2 bg-white/20 rounded-full overflow-hidden">
                  <div
                    className={`h-full transition-all duration-1000 ${previewTimeLeft <= 10 ? 'bg-red-400' : 'bg-white'}`}
                    style={{ width: `${(previewTimeLeft / PREVIEW_SECONDS) * 100}%` }}
                  />
                </div>
                <span className="text-xs text-white/60">preview</span>
              </div>
              {isPreviewOver && (
                <div className="ml-auto">
                  <button
                    onClick={() => buyAllAccess(()=>{}, ()=>{})}
                    className="px-4 py-2 bg-white text-[var(--pf-orange)] rounded-lg text-sm font-bold hover:bg-white/90 transition-colors flex items-center gap-1"
                  >
                    <Icon.Lock /> Get All Music — ${LIFETIME_PRICE} lifetime
                  </button>
                </div>
              )}
            </div>
          )}
        </div>
      </div>

      {/* Content */}
      <div className="pf-container max-w-2xl py-6">
        {/* Search */}
        <div className="relative mb-6">
          <div className="absolute left-4 top-1/2 -translate-y-1/2 text-[var(--pf-text-muted)]">
            <Icon.Search />
          </div>
          <input
            type="text"
            placeholder="Search songs, artists..."
            value={search}
            onChange={(e) => setSearch(e.target.value)}
            className="w-full px-4 py-3 pl-12 rounded-xl border border-[var(--pf-border)] bg-[var(--pf-surface)] text-[var(--pf-text)] placeholder:text-[var(--pf-text-muted)] focus:border-[var(--pf-orange)] focus:outline-none"
          />
        </div>

        {/* Search results or all tracks */}
        {search && (
          <div className="mb-6">
            <p className="text-sm text-[var(--pf-text-muted)] mb-3">{filteredTracks.length} results for "{search}"</p>
            <div className="space-y-2">
              {filteredTracks.map(track => (
                <TrackRow
                  key={track.id}
                  track={track}
                  currentTrack={currentTrack}
                  onPlay={() => playTrack({
                    ...track,
                    duration: typeof track.duration === 'string' ? track.duration.split(':').reduce((acc: number, part: string) => (60 * acc) + parseInt(part), 0) : track.duration || 180
                  } as any)}
                  isPreviewOver={isPreviewOver}
                />
              ))}
            </div>
          </div>
        )}

        {/* All tracks when not searching */}
        {!search && (
          <div className="space-y-2">
            {filteredTracks.map(track => (
              <TrackRow
                key={track.id}
                track={track}
                currentTrack={currentTrack}
                onPlay={() => playTrack({
                  ...track,
                  duration: typeof track.duration === 'string' ? track.duration.split(':').reduce((acc: number, part: string) => (60 * acc) + parseInt(part), 0) : track.duration || 180
                } as any)}
                isPreviewOver={isPreviewOver}
              />
            ))}
          </div>
        )}

        {/* Bottom CTA when preview is over */}
        {isPreviewOver && (
          <div className="mt-8 bg-gradient-to-r from-[var(--pf-orange)]/10 to-purple-500/10 rounded-2xl p-6 border border-[var(--pf-orange)]/20 text-center">
            <h3 className="text-xl font-bold mb-2">Love what you heard?</h3>
            <p className="text-[var(--pf-text-secondary)] text-sm mb-4">
              Get lifetime access to all music for just ${LIFETIME_PRICE}. No subscription. Ever.
            </p>
            <button
              onClick={() => buyAllAccess(()=>{}, ()=>{})}
              className="px-8 py-4 bg-gradient-to-r from-[var(--pf-orange)] to-orange-500 text-white rounded-xl font-bold text-lg hover:opacity-90 transition-opacity shadow-lg"
            >
              🔒 Unlock All Music — ${LIFETIME_PRICE}
            </button>
            <p className="text-xs text-[var(--pf-text-muted)] mt-3">One-time payment. Keep forever.</p>
          </div>
        )}
      </div>
    </div>
  )
}
